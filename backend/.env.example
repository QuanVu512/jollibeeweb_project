NODE_ENV=development
PORT=3000
MONGODB_URI="mongodb+srv://<username>:<password>@<cluster-host>/jollibee?retryWrites=true&w=majority"
JWT_SECRET=thay-bang-chuoi-bi-mat-dai-it-nhat-32-ky-tu
JWT_EXPIRES_IN=1h
COOKIE_NAME=jollibee_admin_token
COOKIE_MAX_AGE_MS=3600000

# Chỉ dùng khi chạy: npm run seed:admin
ADMIN_USERNAME=admin
ADMIN_PASSWORD=thay-bang-mat-khau-admin-manh
ADMIN_DISPLAY_NAME=Quản trị viên
# Chỉ đổi thành true khi thực sự muốn đặt lại mật khẩu admin đã tồn tại
ADMIN_FORCE_RESET=false

# Chỉ cần khi chuyển dữ liệu từ MySQL cũ
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=jollibee_db
